{
  "mcpServers": {
    "atlassian": {
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "AWS Documentation": {
      "command": "uvx awslabs.aws-documentation-mcp-server@latest",
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_DOCUMENTATION_PARTITION": "aws"
      }
    },
    "Figma": {
      "url": "https://mcp.figma.com/mcp"
    },
    "Sentry": {
      "url": "https://mcp.sentry.dev/mcp"
    },
    "Snyk": {
      "command": "snyk mcp -t stdio --experimental",
      "env": {}
    },
    "glean_default": {
      "type": "http",
      "url": "https://eventbrite-be.glean.com/mcp/default",
      "headers": {}
    },
    "context7": {
      "command": "/opt/homebrew/bin/npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "chrome-devtools": {
      "command": "/opt/homebrew/bin/npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ],
      "env": {}
    },
    "notebooks": {
      "command": "node",
      "args": [
        "/Users/ignacio.viejo/.cursor/extensions/googlecloudtools.datacloud-0.3.1-universal/mcp_servers/cli/mcp_proxy_bundle.js",
        "notebooks-cursor"
      ]
    },
    "visualization": {
      "command": "node",
      "args": [
        "/Users/ignacio.viejo/.cursor/extensions/googlecloudtools.datacloud-0.3.1-universal/mcp_servers/cli/mcp_proxy_bundle.js",
        "visualization-cursor"
      ]
    }
  }
}